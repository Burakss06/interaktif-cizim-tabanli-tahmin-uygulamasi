# train_model.py
import os
import numpy as np
import tensorflow as tf

# 1. Arkadaşının hazırladığı verileri yüklüyoruz
PROCESSED_DIR = "data/processed"

X_train = np.load(os.path.join(PROCESSED_DIR, "X_train.npy"))
X_test = np.load(os.path.join(PROCESSED_DIR, "X_test.npy"))
y_train = np.load(os.path.join(PROCESSED_DIR, "y_train.npy"))
y_test = np.load(os.path.join(PROCESSED_DIR, "y_test.npy"))

print("Veriler yüklendi...")
print(f"Eğitim seti boyutu: {X_train.shape}")
print(f"Test seti boyutu: {X_test.shape}")

# 2. CNN (Evrişimli Sinir Ağı) Mimarisini Kuruyoruz
# Bu mimari, çizimlerdeki çizgileri ve şekilleri öğrenmek için en ideal yapıdır.
model = tf.keras.Sequential([
    tf.keras.layers.Conv2D(32, (3, 3), activation='relu', input_shape=(28, 28, 1)),
    tf.keras.layers.MaxPooling2D((2, 2)),
    tf.keras.layers.Dropout(0.25),

    tf.keras.layers.Conv2D(64, (3, 3), activation='relu'),
    tf.keras.layers.MaxPooling2D((2, 2)),
    tf.keras.layers.Dropout(0.25),

    tf.keras.layers.Flatten(),
    tf.keras.layers.Dense(128, activation='relu'),
    tf.keras.layers.Dropout(0.5),
    
    tf.keras.layers.Dense(5, activation='softmax')
])

# 3. Modeli Derleme (Compile)
# Etiketlerimiz (y) direkt sayısal (0, 1, 2..) olduğu için sparse_categorical_crossentropy kullanıyoruz
model.compile(optimizer='adam',
              loss='sparse_categorical_crossentropy',
              metrics=['accuracy'])

# Modelin yapısını ekrana yazdıralım
model.summary()

# 4. MODELİ EĞİTİYORUZ (Train)
# epochs=10: Verilerin üzerinden 10 tur geçerek öğrenecek
print("\nModel eğitimi başlıyor...")
history = model.fit(X_train, y_train,
                    epochs=10,
                    batch_size=64,
                    validation_data=(X_test, y_test))

# 5. Başarıyla eğitilen modeli kaydediyoruz
model.save("quickdraw_model.keras")
print("\nTebrikler! Model başarıyla eğitildi ve 'quickdraw_model.keras' olarak kaydedildi.")